{
  "version": 1,
  "groups": [
    { "name": "company", "label": "Empresa" },
    { "name": "auth", "label": "Autenticacao" },
    { "name": "products", "label": "Produtos" },
    { "name": "orders", "label": "Pedidos" },
    { "name": "webhook", "label": "Webhook" }
  ],
  "fields": [
    {
      "key": "idEmpresa",
      "label": "ID da Empresa",
      "type": "int",
      "required": false,
      "group": "company",
      "default": "1",
      "validation": { "min": 1 }
    },
    {
      "key": "apiToken",
      "label": "Token da API",
      "type": "secret",
      "required": true,
      "group": "auth"
    },
    {
      "key": "dateFilter",
      "label": "Janela de Pedidos (dias)",
      "type": "int",
      "required": false,
      "group": "orders",
      "default": "5",
      "validation": { "min": 1 }
    },
    {
      "key": "simpleProduct",
      "label": "Produto Simples",
      "type": "bool",
      "required": false,
      "group": "products",
      "default": "false"
    },
    {
      "key": "hasCreateProductCodRefMaisCodCor",
      "label": "Usar referência + cor",
      "type": "bool",
      "required": false,
      "group": "products",
      "default": "false"
    },
    {
      "key": "webhookIsEnabled",
      "label": "Habilitar Webhook",
      "type": "bool",
      "required": false,
      "group": "webhook",
      "default": "false"
    }
  ]
}
